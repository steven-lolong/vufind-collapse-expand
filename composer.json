{
    "name": "ubtue/vufind-collapse-expand",
    "description": "Adding Solr Collapse & Expand functionality to VuFind, initially based on finc/vufind-results-grouping.",
    "authors": [
        {
            "name": "Cornelius Amzar",
            "email": "cornelius.amzar@bsz-bw.de"
        },
        {
            "name": "Dorian Merz",
            "email": "merz@ub.uni-leipzig.de"
        },
