            "name": "Alexander Purr",
            "email": "purr@ub.uni-leipzig.de"
        },
        {
            "name": "Robert Lange",
            "email": "lange@ub.uni-leipzig.de"
        },
        {
            "name": "Mario Trojan",
            "email": "mario.trojan@uni-tuebingen.de"
        },
        {
            "name": "Steven Lolong",
            "email": "steven.lolong@uni-tuebingen.de"
        }
    ],
    "autoload": {
        "psr-4": {
            "VuFindCollapseExpand\\": "src/"
        }
    },
    "extra": {
        "vufind": {
            "themes": {
                "res/theme": "vufind-collapse-expand"
            }
        }
    },
    "config": {
        "platform": {
            "php": "8.1"
        }
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "3.75.0",
        "phpmd/phpmd": "2.15.0",
        "phpstan/phpstan": "2.1.14",
        "phing/phing": "3.0.1",
        "squizlabs/php_codesniffer": "3.12.2",
        "rector/rector": "^2.0.0"
    }
}
