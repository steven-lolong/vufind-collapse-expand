{
    "name": "ubtue/vufind-collapse-expand",
    "description": "Adding Solr Collapse & Expand functionality to VuFind, initially based on finc/vufind-results-grouping.",
    "autoload": {
        "psr-4": {
            "VuFindCollapseExpand\\": "src/"
        }
    },
    "config": {
        "platform": {
            "php": "8.1"
        }
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "3.75.0",
        "phpmd/phpmd": "2.15.0",
        "phpstan/phpstan": "2.1.14",
        "phing/phing": "3.0.1",
        "squizlabs/php_codesniffer": "3.12.2",
        "rector/rector": "^2.0.0"
    }
}
